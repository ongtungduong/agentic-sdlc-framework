# ask-ranger kit — development-time ignore list
# (The fragment appended to target repos lives at template/.gitignore.append)

# Node
node_modules/
package-lock.json

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~

# Env files (secrets)
.env
.env.*
!.env.example

# GitNexus index (local state)
.gitnexus/

# GitNexus auto-writes skills here when indexing the kit root; the
# canonical versions already live under template/.claude/skills/gitnexus/.
.claude/skills/

# Git worktrees
.worktrees/
